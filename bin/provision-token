#!/usr/bin/env bash
# provision-token — mint (idempotently) a scoped API token for the self-host dashboard.
#
# docker-compose.dashboard.yml documents a 3-step bring-up: "1. stack up, 2. MINT A TOKEN, 3. dashboard
# up with DASHBOARD_API_KEY=<token>". Step 2 was a manual, fiddly admin-api call with no repeatable
# form — so a DB reset (or a fresh `up`) left the dashboard's baked key dangling and every request 401'd
# (the gateway → admin-api /internal/validate correctly rejects a token that isn't in the DB). This is
# that step as ONE idempotent command: resolve-or-create the self-host user, mint a (bot,tx) token, and
# print ONLY the token on stdout so it pipes straight into the dashboard deploy.
#
# Usage (the operator runs it — it needs the stack's ADMIN_TOKEN, the same secret the stack signs with):
#   ADMIN_TOKEN=<admin-secret> deploy/compose/bin/provision-token
#   → vxa_...                                   # the scoped token, nothing else, on stdout
#
# Wire it into the dashboard in one line:
#   DASHBOARD_API_KEY=$(ADMIN_TOKEN=<admin-secret> deploy/compose/bin/provision-token) \
#     docker compose -f docker-compose.yml -f docker-compose.dashboard.yml up -d dashboard
#
# Env knobs:
#   ADMIN_TOKEN     (required) the stack admin secret (X-Admin-API-Key).
#   ADMIN_API_URL   admin-api base (default http://127.0.0.1:18057, the compose default host port).
#   EMAIL           the self-host user's email (default self-host@vexa.ai) — stable, so reruns reuse it.
#   SCOPES          comma scopes (default bot,tx — bots + transcript reads; the dashboard needs both).
#   MAX_BOTS        max_concurrent_bots on create (default 5).
set -euo pipefail

ADMIN_API="${ADMIN_API_URL:-http://127.0.0.1:18057}"
EMAIL="${EMAIL:-self-host@vexa.ai}"
SCOPES="${SCOPES:-bot,tx}"
MAX_BOTS="${MAX_BOTS:-5}"
: "${ADMIN_TOKEN:?set ADMIN_TOKEN (the stack admin secret the stack signs with)}"

H=(-H "X-Admin-API-Key: ${ADMIN_TOKEN}")
_id() { python3 -c 'import sys,json;print(json.load(sys.stdin)["id"])'; }
_tok() { python3 -c 'import sys,json;print(json.load(sys.stdin)["token"])'; }

# Resolve-or-create the user (admin-api's create is itself idempotent: existing email → 200 + the row).
uid="$(curl -fsS "${H[@]}" "${ADMIN_API}/admin/users/email/${EMAIL}" 2>/dev/null | _id 2>/dev/null || true)"
if [ -z "${uid}" ]; then
  uid="$(curl -fsS "${H[@]}" -H 'Content-Type: application/json' \
        -d "{\"email\":\"${EMAIL}\",\"max_concurrent_bots\":${MAX_BOTS}}" \
        "${ADMIN_API}/admin/users" | _id)"
fi

# Mint a fresh scoped token for that user (tokens are additive; old ones keep working until deleted).
curl -fsS "${H[@]}" -X POST "${ADMIN_API}/admin/users/${uid}/tokens?scopes=${SCOPES}" | _tok
