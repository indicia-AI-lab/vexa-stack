# vexa-stack — omgevingsconfig. Kopieer naar .env en vul de secrets.
# LET OP (upstream-erfenis): comments altijd op een EIGEN regel, nooit achter een
# waarde — sommige parsers nemen een trailing comment op in de waarde.

# --- images (gepind, bewust geen rolling v012-tag) ---------------------------
IMAGE_TAG=v0.12.15
BROWSER_IMAGE=vexaai/vexa-bot:v0.12.15

# --- host-poorten (alle binds op 127.0.0.1) ----------------------------------
# Publieke API-voordeur (X-API-Key); Vector praat hiertegen.
API_GATEWAY_HOST_PORT=18056
# admin-api: users + API-keys minten (X-Admin-API-Key).
ADMIN_API_PORT=18057
MEETING_API_PORT=18080
RUNTIME_API_PORT=18090
POSTGRES_HOST_PORT=5458
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# --- docker ------------------------------------------------------------------
# GID van de docker-groep op de host: `getent group docker | cut -d: -f3`.
# 0 volstaat als de runtime-container als root draait (upstream-default).
DOCKER_GID=0
LOG_LEVEL=info

# --- database ----------------------------------------------------------------
DB_NAME=vexa
DB_USER=postgres
# genereer: openssl rand -hex 24
DB_PASSWORD=changeme

# --- object store (MinIO) — hier landen de opnames ---------------------------
MINIO_ACCESS_KEY=vexa-access-key
# genereer: openssl rand -hex 24
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=vexa
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

# --- stack-secrets -----------------------------------------------------------
# genereer beide: openssl rand -hex 32
ADMIN_TOKEN=changeme
INTERNAL_API_SECRET=changeme

# --- bot ---------------------------------------------------------------------
# Naam zoals deelnemers hem zien; definitieve naam is PO-vraag 2 in ADR-0004
# (vector-repo). Per request te overschrijven met bot_name in POST /bots.
DEFAULT_BOT_NAME=Indicia Notulist

# --- capture-only (niet wijzigen zonder ADR-0004 te herzien) -----------------
# Expliciet false/true — een lege waarde betekent hier NIET false (upstream
# v0.12.5-bug: leeg werd stilletjes capture-only zonder foutmelding).
TRANSCRIBE_ENABLED=false
RECORDING_ENABLED=true

# --- gateway edge guard ------------------------------------------------------
GUARD_ENABLED=true
GUARD_RATE_LIMIT_RPM=600
